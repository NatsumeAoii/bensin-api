# Frontend configuration for the Bensin-API dashboard.
# Copy to `.env.local` and adjust as needed. All values are optional.

# Base URL the dashboard fetches the static JSON API from.
# Leave unset to fetch the generated v1/ files from the same deployment as the
# dashboard, including v1/history/ price-history files.
#
# To serve locally generated v1/ data from another host, run a static server at
# the repo root (e.g. `npx serve .` or `python -m http.server`) and point this
# at it:
#   VITE_API_BASE_URL=http://localhost:3000
# VITE_API_BASE_URL=https://example.com/bensin-api
