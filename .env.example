# Frontend configuration for the Bensin-API dashboard.
# Copy to `.env.local` and adjust as needed. All values are optional.

# Base URL the dashboard fetches the static JSON API from.
# Defaults to the production GitHub Pages deployment when unset.
#
# To serve locally generated v1/ data, run a static server at the repo root
# (e.g. `npx serve .` or `python -m http.server`) and point this at it:
#   VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=https://nasgunawann.github.io/bensin-api
