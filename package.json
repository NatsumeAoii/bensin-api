{
  "name": "bensin-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Indonesia Fuel Price API — data pipeline + web dashboard",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && node scripts/check-bundle-size.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "vitest run && python -m pytest pipeline/tests/",
    "clean": "node -e \"import('node:fs').then(f=>f.rm('dist',{recursive:true,force:true},()=>{}))\"",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "pipeline": "python pipeline/fetch_normalize.py",
    "pipeline:fetch": "python pipeline/fetch_normalize.py --fetch",
    "pipeline:test": "python -m pytest pipeline/tests/"
  },
  "dependencies": {
    "lightningcss": "^1.32.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.16.0",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.14"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
